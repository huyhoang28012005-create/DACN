generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                    Int             @id @default(autoincrement())
  name                  String          @db.VarChar(255)
  email                 String          @unique @db.VarChar(255)
  password              String          @db.VarChar(255)
  role                  Role            @default(STUDENT)
  department            String?         @db.VarChar(255)
  phone                 String?         @db.VarChar(20)
  student_class         String?         @db.VarChar(100)
  created_at            DateTime        @default(now())
  updated_at            DateTime        @updatedAt
  avatar_url            String?         @db.VarChar(500)
  is_active             Boolean         @default(true)
  refresh_token         String?         @db.Text
  blacklist_reason      String?         @db.Text
  failed_login_attempts Int             @default(0)
  locked_until          DateTime?
  is_mfa_enabled        Boolean         @default(false)
  mfa_secret            String?         @db.VarChar(255)
  is_deleted            Boolean         @default(false)
  trust_score           Int             @default(100)
  audit_logs            AuditLog[]
  bookings              Booking[]
  check_in_records      CheckInRecord[]
  comments              Comment[]
  courses               Course[]
  course_enrollments    CourseEnrollment[]
  notifications         Notification[]
  reports               Report[]
  login_history         LoginHistory[]
  maintenance_schedules MaintenanceSchedule[]
  waitlists             Waitlist[]
  community_posts       CommunityPost[]
  community_comments    CommunityComment[]
  ratings               Rating[]
  skill_badges          UserSkillBadge[]
  publications          UserPublication[]
  assigned_reports      Report[]            @relation("ReportAssignee")
  penalties             Penalty[]
  chemical_transactions ChemicalTransaction[]
  inventory_checks      InventoryCheck[]

  @@map("users")
}

model Notification {
  id         Int      @id @default(autoincrement())
  user_id    Int
  title      String   @db.VarChar(255)
  message    String   @db.Text
  type       String   @default("info") @db.VarChar(50)
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id], map: "notifications_user_id_fkey")
  @@map("notifications")
}

model Course {
  id              Int             @id @default(autoincrement())
  name            String          @db.VarChar(255)
  code            String          @unique @db.VarChar(100)
  semester        String          @default("Kỳ 1") @db.VarChar(50)
  academic_year   String          @default("2025-2026") @db.VarChar(50)
  created_at      DateTime        @default(now())
  instructor_id   Int
  is_deleted      Boolean         @default(false)
  bookings        Booking[]
  chemical_usages ChemicalUsage[]
  chemical_limits ChemicalLimit[]
  instructor      User            @relation(fields: [instructor_id], references: [id], onDelete: Cascade)
  enrollments     CourseEnrollment[]

  @@index([instructor_id], map: "courses_instructor_id_fkey")
  @@map("courses")
}

model CourseEnrollment {
  id              Int       @id @default(autoincrement())
  course_id       Int
  student_id      Int
  enrolled_at     DateTime  @default(now())

  course          Course    @relation(fields: [course_id], references: [id], onDelete: Cascade)
  student         User      @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([course_id, student_id])
  @@map("course_enrollments")
}

model Room {
  id                  Int             @id @default(autoincrement())
  name                String          @unique @db.VarChar(100)
  location            String          @db.VarChar(255)
  capacity            Int
  has_air_conditioner Boolean         @default(true)
  created_at          DateTime        @default(now())
  image_url           String?         @db.VarChar(500)
  is_deleted          Boolean         @default(false)
  bookings              Booking[]
  check_in_records      CheckInRecord[]
  equipment             Equipment[]
  reports               Report[]
  investments           LabInvestment[]
  publications          ScientificPublication[]
  maintenance_schedules MaintenanceSchedule[]
  waitlists             Waitlist[]
  ratings               Rating[]

  @@map("rooms")
}

model Equipment {
  id               Int             @id @default(autoincrement())
  name             String          @db.VarChar(255)
  serial_number    String          @unique @db.VarChar(100)
  status           EquipmentStatus @default(AVAILABLE)
  room_id          Int
  last_maintenance DateTime?       @db.Date
  purchase_date    DateTime?       @db.Date
  value            Float?
  maintenance_interval_months Int?
  created_at       DateTime        @default(now())
  image_url        String?         @db.VarChar(500)
  row_version      Int             @default(1)
  is_deleted       Boolean         @default(false)
  supplier_id      Int?
  bookings              Booking[]
  check_in_records      CheckInRecord[]
  comments              Comment[]
  room                  Room            @relation(fields: [room_id], references: [id], onDelete: Cascade)
  supplier              Supplier?       @relation(fields: [supplier_id], references: [id], onDelete: SetNull)
  reports               Report[]
  maintenance_schedules MaintenanceSchedule[]
  waitlists             Waitlist[]
  community_posts       CommunityPost[]
  ratings               Rating[]
  required_badges       SkillBadge[]    @relation("EquipmentSkillRequirements")

  @@index([status])
  @@index([room_id], map: "equipment_room_id_fkey")
  @@map("equipment")
}

model Chemical {
  id              Int             @id @default(autoincrement())
  name            String          @db.VarChar(255)
  formula         String?         @db.VarChar(100)
  quantity_stock  Float           @default(0)
  unit            String          @db.VarChar(20)
  storage_conditions String?      @db.VarChar(255)
  min_stock_alert Float           @default(5)
  created_at      DateTime        @default(now())
  expiration_date DateTime?       @db.Date
  image_url       String?         @db.VarChar(500)
  is_deleted      Boolean         @default(false)
  supplier_id     Int?
  supplier        Supplier?       @relation(fields: [supplier_id], references: [id], onDelete: SetNull)
  usages          ChemicalUsage[]
  limits          ChemicalLimit[]
  transactions    ChemicalTransaction[]
  inventory_checks InventoryCheck[]

  @@map("chemicals")
}

model ChemicalLimit {
  id            Int      @id @default(autoincrement())
  course_id     Int
  chemical_id   Int
  max_quantity  Float
  unit          String   @db.VarChar(20)
  description   String?  @db.Text
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  course        Course   @relation(fields: [course_id], references: [id], onDelete: Cascade)
  chemical      Chemical @relation(fields: [chemical_id], references: [id], onDelete: Cascade)

  @@unique([course_id, chemical_id])
  @@index([course_id], map: "chemical_limits_course_id_fkey")
  @@index([chemical_id], map: "chemical_limits_chemical_id_fkey")
  @@map("chemical_limits")
}

model Booking {
  id               Int             @id @default(autoincrement())
  user_id          Int
  room_id          Int
  equipment_id     Int?
  start_time       DateTime
  end_time         DateTime
  status           BookingStatus   @default(PENDING)
  purpose          String          @db.Text
  created_at       DateTime        @default(now())
  course_id        Int?
  row_version      Int             @default(1)
  is_deleted       Boolean         @default(false)
  course           Course?         @relation(fields: [course_id], references: [id])
  equipment        Equipment?      @relation(fields: [equipment_id], references: [id])
  room             Room            @relation(fields: [room_id], references: [id], onDelete: Cascade)
  user             User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  check_in_records CheckInRecord[]
  chemical_usages  ChemicalUsage[]
  comments         Comment[]

  @@index([room_id, start_time, end_time])
  @@index([equipment_id, start_time, end_time])
  @@index([status])
  @@index([course_id], map: "bookings_course_id_fkey")
  @@index([user_id], map: "bookings_user_id_fkey")
  @@map("bookings")
}

model ChemicalUsage {
  id            Int      @id @default(autoincrement())
  booking_id    Int
  chemical_id   Int
  quantity_used Float
  used_at       DateTime @default(now())
  course_id     Int?
  booking       Booking  @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  chemical      Chemical @relation(fields: [chemical_id], references: [id], onDelete: Cascade)
  course        Course?  @relation(fields: [course_id], references: [id])

  @@index([booking_id], map: "chemical_usage_booking_id_fkey")
  @@index([chemical_id], map: "chemical_usage_chemical_id_fkey")
  @@index([course_id], map: "chemical_usage_course_id_fkey")
  @@map("chemical_usage")
}

model AuditLog {
  id            Int      @id @default(autoincrement())
  action        String   @db.VarChar(255)
  table_name    String   @db.VarChar(100)
  record_id     Int
  user_id       Int?
  details       String?  @db.Text
  timestamp     DateTime @default(now())
  current_hash  String?  @db.VarChar(64)
  previous_hash String?  @db.VarChar(64)
  user          User?    @relation(fields: [user_id], references: [id])

  @@index([user_id], map: "audit_logs_user_id_fkey")
  @@map("audit_logs")
}

model Report {
  id           Int          @id @default(autoincrement())
  user_id      Int
  equipment_id Int?
  room_id      Int?
  title        String       @db.VarChar(255)
  description  String       @db.Text
  status       ReportStatus @default(OPEN)
  image_url    String?      @db.VarChar(500)
  created_at   DateTime     @default(now())
  is_deleted   Boolean      @default(false)
  assigned_to_id Int?
  comments     Comment[]
  equipment    Equipment?   @relation(fields: [equipment_id], references: [id])
  room         Room?        @relation(fields: [room_id], references: [id])
  user         User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  assignee     User?        @relation("ReportAssignee", fields: [assigned_to_id], references: [id])
  penalties    Penalty[]

  @@index([equipment_id], map: "reports_equipment_id_fkey")
  @@index([room_id], map: "reports_room_id_fkey")
  @@index([user_id], map: "reports_user_id_fkey")
  @@map("reports")
}

model CheckInRecord {
  id           Int        @id @default(autoincrement())
  booking_id   Int?
  user_id      Int
  equipment_id Int?
  room_id      Int?
  status       String     @default("ACTIVE") @db.VarChar(50)
  check_in     DateTime   @default(now())
  check_out    DateTime?
  booking      Booking?   @relation(fields: [booking_id], references: [id])
  equipment    Equipment? @relation(fields: [equipment_id], references: [id])
  room         Room?      @relation(fields: [room_id], references: [id])
  user         User       @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([booking_id], map: "check_in_records_booking_id_fkey")
  @@index([equipment_id], map: "check_in_records_equipment_id_fkey")
  @@index([room_id], map: "check_in_records_room_id_fkey")
  @@index([user_id], map: "check_in_records_user_id_fkey")
  @@map("check_in_records")
}

model Comment {
  id           Int        @id @default(autoincrement())
  content      String     @db.Text
  user_id      Int
  report_id    Int?
  booking_id   Int?
  parent_id    Int?
  created_at   DateTime   @default(now())
  equipment_id Int?
  updated_at   DateTime   @updatedAt
  booking      Booking?   @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  equipment    Equipment? @relation(fields: [equipment_id], references: [id], onDelete: Cascade)
  parent       Comment?   @relation("CommentReplies", fields: [parent_id], references: [id], onDelete: Cascade)
  replies      Comment[]  @relation("CommentReplies")
  report       Report?    @relation(fields: [report_id], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([booking_id], map: "comments_booking_id_fkey")
  @@index([equipment_id], map: "comments_equipment_id_fkey")
  @@index([parent_id], map: "comments_parent_id_fkey")
  @@index([report_id], map: "comments_report_id_fkey")
  @@index([user_id], map: "comments_user_id_fkey")
  @@map("comments")
}

model SystemSetting {
  id          Int      @id @default(autoincrement())
  key         String   @unique @db.VarChar(100)
  value       String   @db.Text
  description String?  @db.VarChar(255)
  category    String   @default("GENERAL") @db.VarChar(50)
  updated_at  DateTime @updatedAt

  @@map("system_settings")
}

enum Role {
  ADMIN
  TECHNICIAN
  INSTRUCTOR
  STUDENT
}

enum EquipmentStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  BROKEN
}

enum BookingStatus {
  PENDING
  APPROVED
  IN_USE
  COMPLETED
  CANCELED
  REJECTED
  WAITLISTED
  OVERDUE
}

enum ReportStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  REJECTED
  PENDING
}

model LabInvestment {
  id          Int      @id @default(autoincrement())
  room_id     Int
  amount      Float
  year        Int
  description String?  @db.Text
  source      String?  @db.VarChar(255)
  room        Room     @relation(fields: [room_id], references: [id], onDelete: Cascade)
  created_at  DateTime @default(now())

  @@index([room_id], map: "lab_investments_room_id_fkey")
  @@map("lab_investments")
}

model ScientificPublication {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(500)
  authors     String   @db.VarChar(500)
  journal     String   @db.VarChar(255)
  year        Int
  doi         String?  @db.VarChar(100)
  category    String?  @db.VarChar(100)
  room_id     Int
  room        Room     @relation(fields: [room_id], references: [id], onDelete: Cascade)
  created_at  DateTime @default(now())

  authors_users UserPublication[]

  @@index([room_id], map: "scientific_publications_room_id_fkey")
  @@map("scientific_publications")
}

model UserPublication {
  id              Int       @id @default(autoincrement())
  user_id         Int
  publication_id  Int
  role            String    @default("author") @db.VarChar(50) // author, co_author, reviewer
  is_corresponding Boolean @default(false)
  created_at      DateTime  @default(now())

  user         User                @relation(fields: [user_id], references: [id], onDelete: Cascade)
  publication  ScientificPublication @relation(fields: [publication_id], references: [id], onDelete: Cascade)

  @@unique([user_id, publication_id])
  @@index([user_id], map: "user_publications_user_id_fkey")
  @@index([publication_id], map: "user_publications_publication_id_fkey")
  @@map("user_publications")
}

model LoginHistory {
  id         Int      @id @default(autoincrement())
  user_id    Int
  ip_address String   @db.VarChar(50)
  device     String   @db.VarChar(255)
  location   String?  @db.VarChar(255)
  status     String   @default("Thành công") @db.VarChar(50)
  created_at DateTime @default(now())

  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id], map: "login_history_user_id_fkey")
  @@map("login_history")
}

model EquipmentCombo {
  id          Int                  @id @default(autoincrement())
  name        String               @db.VarChar(255)
  description String?              @db.Text
  image_url   String?              @db.VarChar(500)
  items       EquipmentComboItem[]
  
  @@map("equipment_combos")
}

model EquipmentComboItem {
  id              Int            @id @default(autoincrement())
  combo_id        Int
  equipment_name  String         @db.VarChar(255)
  quantity        Int            @default(1)
  combo           EquipmentCombo @relation(fields: [combo_id], references: [id], onDelete: Cascade)

  @@index([combo_id], map: "equipment_combo_items_combo_id_fkey")
  @@map("equipment_combo_items")
}

model MaintenanceSchedule {
  id           Int        @id @default(autoincrement())
  room_id      Int?
  equipment_id Int?
  start_time   DateTime
  end_time     DateTime
  description  String     @db.Text
  cost         Float?
  created_by   Int
  created_at   DateTime   @default(now())
  
  room         Room?      @relation(fields: [room_id], references: [id], onDelete: Cascade)
  equipment    Equipment? @relation(fields: [equipment_id], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [created_by], references: [id], onDelete: Cascade)

  @@index([room_id], map: "maintenance_schedules_room_id_fkey")
  @@index([equipment_id], map: "maintenance_schedules_equipment_id_fkey")
  @@index([start_time])
  @@index([created_by], map: "maintenance_schedules_created_by_fkey")
  @@map("maintenance_schedules")
}

model Waitlist {
  id           Int      @id @default(autoincrement())
  user_id      Int
  equipment_id Int?
  room_id      Int?
  created_at   DateTime @default(now())
  is_notified  Boolean  @default(false)

  user         User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  equipment    Equipment? @relation(fields: [equipment_id], references: [id], onDelete: Cascade)
  room         Room?      @relation(fields: [room_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([equipment_id])
  @@index([room_id])
  @@map("waitlists")
}

model CommunityPost {
  id           Int      @id @default(autoincrement())
  author_id    Int
  title        String   @db.VarChar(255)
  content      String   @db.Text
  equipment_id Int?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  upvotes      Int      @default(0)
  views        Int      @default(0)

  author       User       @relation(fields: [author_id], references: [id], onDelete: Cascade)
  equipment    Equipment? @relation(fields: [equipment_id], references: [id], onDelete: SetNull)
  comments     CommunityComment[]

  @@index([author_id])
  @@index([equipment_id])
  @@map("community_posts")
}

model CommunityComment {
  id         Int      @id @default(autoincrement())
  post_id    Int
  author_id  Int
  content    String   @db.Text
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  upvotes    Int      @default(0)

  post       CommunityPost @relation(fields: [post_id], references: [id], onDelete: Cascade)
  author     User          @relation(fields: [author_id], references: [id], onDelete: Cascade)

  @@index([post_id])
  @@index([author_id])
  @@map("community_comments")
}

model Rating {
  id           Int      @id @default(autoincrement())
  user_id      Int
  equipment_id Int?
  room_id      Int?
  score        Int      // 1 to 5
  comment      String?  @db.Text
  created_at   DateTime @default(now())

  user         User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  equipment    Equipment? @relation(fields: [equipment_id], references: [id], onDelete: Cascade)
  room         Room?      @relation(fields: [room_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([equipment_id])
  @@index([room_id])
  @@map("ratings")
}

model SkillBadge {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(255)
  description String   @db.Text
  icon_url    String?  @db.VarChar(500)
  created_at  DateTime @default(now())

  user_badges UserSkillBadge[]
  equipment   Equipment[] @relation("EquipmentSkillRequirements")

  @@map("skill_badges")
}

model UserSkillBadge {
  id           Int      @id @default(autoincrement())
  user_id      Int
  badge_id     Int
  issued_at    DateTime @default(now())

  user         User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  badge        SkillBadge @relation(fields: [badge_id], references: [id], onDelete: Cascade)

  @@unique([user_id, badge_id])
  @@index([user_id])
  @@index([badge_id])
  @@map("user_skill_badges")
}

model Supplier {
  id              Int       @id @default(autoincrement())
  name            String    @db.VarChar(255)
  contact_person  String?   @db.VarChar(255)
  phone           String?   @db.VarChar(20)
  email           String?   @db.VarChar(255)
  address         String?   @db.Text
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  equipment       Equipment[]
  chemicals       Chemical[]

  @@map("suppliers")
}

model ChemicalTransaction {
  id          Int      @id @default(autoincrement())
  chemical_id Int
  user_id     Int
  type        TransactionType
  quantity    Float
  note        String?  @db.Text
  created_at  DateTime @default(now())

  chemical    Chemical @relation(fields: [chemical_id], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([chemical_id])
  @@index([user_id])
  @@map("chemical_transactions")
}

enum TransactionType {
  RESTOCK
  USAGE
  DISPOSAL
}

model Penalty {
  id          Int      @id @default(autoincrement())
  user_id     Int
  report_id   Int?
  amount      Float
  reason      String   @db.Text
  status      PenaltyStatus @default(PENDING)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  report      Report?  @relation(fields: [report_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([report_id])
  @@map("penalties")
}

enum PenaltyStatus {
  PENDING
  PAID
  CANCELLED
}

model InventoryCheck {
  id            Int      @id @default(autoincrement())
  chemical_id   Int
  user_id       Int
  expected_qty  Float
  actual_qty    Float
  discrepancy   Float
  note          String?  @db.Text
  created_at    DateTime @default(now())

  chemical      Chemical @relation(fields: [chemical_id], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([chemical_id])
  @@index([user_id])
  @@map("inventory_checks")
}
